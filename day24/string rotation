def is_rotation(s1, s2):
    if len(s1) != len(s2):
        return False
    
    temp = s1 + s1
    return s2 in temp

# Input
s1 = input("Enter first string: ")
s2 = input("Enter second string: ")

# Output
if is_rotation(s1, s2):
    print("Yes, it is a rotation")
else:
    print("No, it is not a rotation")