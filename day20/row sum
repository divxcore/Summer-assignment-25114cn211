r = int(input("enter number of rows: "))
c = int(input("enter number of columns: "))

mat = []
print("enter matrix:")
for i in range(r):
    row = []
    for j in range(c):
        row.append(int(input()))
    mat.append(row)

print("row-wise sum:")
for i in range(r):
    s = 0
    for j in range(c):
        s += mat[i][j]
    print(s)