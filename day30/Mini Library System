# Mini Library System

books = []

def add_book():
    book = input("Enter book name: ")
    books.append(book)
    print("Book added!\n")

def show_books():
    print("\nAvailable Books:")
    for b in books:
        print(b)
    print()

def issue_book():
    book = input("Enter book to issue: ")
    if book in books:
        books.remove(book)
        print("Book issued!\n")
    else:
        print("Book not available\n")

def return_book():
    book = input("Enter book to return: ")
    books.append(book)
    print("Book returned!\n")

while True:
    print("1.Add Book\n2.Show Books\n3.Issue Book\n4.Return Book\n5.Exit")
    ch = input("Choice: ")

    if ch == '1':
        add_book()
    elif ch == '2':
        show_books()
    elif ch == '3':
        issue_book()
    elif ch == '4':
        return_book()
    elif ch == '5':
        break
    else:
        print("Invalid choice\n")