# Movie Recommendation System

movies = ["Inception", "Avengers", "Titanic", "The Conjuring", "Interstellar"]
genres = ["Sci-Fi", "Action", "Romance", "Horror", "Sci-Fi"]

def add_movie():
    name = input("Enter movie name: ")
    genre = input("Enter genre: ")
    movies.append(name)
    genres.append(genre)
    print("Movie added successfully!\n")

def display_movies():
    print("\n--- Movie List ---")
    for i in range(len(movies)):
        print(f"{movies[i]} ({genres[i]})")
    print()

def recommend_movie():
    user_genre = input("Enter preferred genre: ")
    found = False
    
    print("\nRecommended Movies:")
    for i in range(len(genres)):
        if genres[i].lower() == user_genre.lower():
            print(movies[i])
            found = True
    
    if not found:
        print("No movies found for this genre.\n")

def search_movie():
    name = input("Enter movie name to search: ")
    if name in movies:
        index = movies.index(name)
        print(f"Found: {movies[index]} ({genres[index]})\n")
    else:
        print("Movie not found\n")

# Menu
while True:
    print("1. Add Movie")
    print("2. Display Movies")
    print("3. Recommend by Genre")
    print("4. Search Movie")
    print("5. Exit")
    
    choice = input("Enter choice: ")
    
    if choice == '1':
        add_movie()
    elif choice == '2':
        display_movies()
    elif choice == '3':
        recommend_movie()
    elif choice == '4':
        search_movie()
    elif choice == '5':
        print("Exiting...")
        break
    else:
        print("Invalid choice\n")