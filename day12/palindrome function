def is_palindrome(num):
    original = num
    reversed_num = 0

    while num != 0:
        remainder = num % 10
        reversed_num = reversed_num * 10 + remainder
        num //= 10

    return original == reversed_num



n = int(input("Enter a number: "))

if is_palindrome(n):
    print("Palindrome")
else:
    print("Not Palindrome")