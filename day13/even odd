arr1 = [1,2,3]
even = []
odd = []
for num in arr1:
    if num%2 == 0:
        even.append(num)
    else:
        odd.append(num)
print(even)
print(odd)

even_count = 0
odd_count = 0

for num in arr1:
    if num % 2 == 0:
        even_count += 1
    else:
        odd_count += 1

print("Even count =", even_count)
print("Odd count =", odd_count)